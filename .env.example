# Copy this file to .env and fill in the real values.
# DO NOT commit .env — it is gitignored.

# Notion internal integration secret (use NOTION_INTEGRATION_TOKEN from your env).
# The integration must be connected to NOTION_PARENT_PAGE_ID via "Add connections".
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxx

# Notion page where the "ARA Web Image Library" DB will be created.
# Required only by scripts/setup-notion-db.js. Can be a page ID or full Notion URL.
NOTION_PARENT_PAGE_ID=

# Notion database ID returned by setup-notion-db.js. Required for convert-images.js.
NOTION_DATABASE_ID=

# Base URL where the committed .webp files are publicly served.
# After creating the GitHub repo, set this to:
#   https://raw.githubusercontent.com/<your-user>/ara-web-image-library/main/webp-library
GITHUB_REPO_RAW_BASE=https://raw.githubusercontent.com/CHANGEME/ara-web-image-library/main/webp-library
